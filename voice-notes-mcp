#!/usr/bin/env bash
# Launcher for the voice-notes MCP server (stdio transport). Runs the read-only
# server that exposes already-generated notes to MCP clients (Claude Code /
# Desktop). Uses the project venv; no GPU libs needed (it only reads files).
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd -P)"
VENV="$HERE/.venv"
PY="$VENV/bin/python"

if [[ ! -x "$PY" ]]; then
    echo "venv not found at $VENV. Run: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
    exit 1
fi

export PYTHONUNBUFFERED=1
exec "$PY" "$HERE/voice_notes_mcp.py" "$@"
