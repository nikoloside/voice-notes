#!/usr/bin/env bash
# Launcher for voice-notes. Activates the venv and exposes pip-installed
# CUDA/cuDNN libraries to faster-whisper.
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd -P)"
VENV="$HERE/.venv"
PY="$VENV/bin/python"

if [[ ! -x "$PY" ]]; then
    echo "venv not found at $VENV. Run: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
    exit 1
fi

NVIDIA_LIBS="$("$PY" - <<'PYEOF'
import glob, os, importlib.util
spec = importlib.util.find_spec("nvidia")
if spec and spec.submodule_search_locations:
    base = list(spec.submodule_search_locations)[0]
    print(os.pathsep.join(sorted(set(glob.glob(base + "/*/lib")))))
PYEOF
)"
if [[ -n "${NVIDIA_LIBS}" ]]; then
    export LD_LIBRARY_PATH="${NVIDIA_LIBS}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

export PYTHONUNBUFFERED=1
exec "$PY" "$HERE/record_notes.py" "$@"
